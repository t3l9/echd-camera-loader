# Шаблон файла переменных окружения
# Скопируйте этот файл в .env и заполните своими данными

# Версия приложения
APP_VERSION=9.3.0

# URL сайта ЕЦХД
ECHD_URL=https://echd.mos.ru/login/auth/

# Google Sheets - URL вашей таблицы
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/ВАШ_ID_ТАБЛИЦЫ/edit

# Google Sheets разрешения
GOOGLE_SCOPES=https://www.googleapis.com/auth/spreadsheets

# Сервисный аккаунт Google
GOOGLE_SERVICE_ACCOUNT_TYPE=service_account
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=ваш-project-id
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=ваш-private-key-id
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nВАШ_КЛЮЧ\n-----END PRIVATE KEY-----"
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=ваш-email@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_CLIENT_ID=ваш-client-id
GOOGLE_SERVICE_ACCOUNT_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_SERVICE_ACCOUNT_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_SERVICE_ACCOUNT_AUTH_PROVIDER_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_SERVICE_ACCOUNT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/ваш-email.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_UNIVERSE_DOMAIN=googleapis.com

# Логирование (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOGGING_LEVEL=INFO
